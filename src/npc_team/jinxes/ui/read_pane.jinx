jinx_name: read_pane
description: >
  Read content from any pane. Works on all types: editor (file text),
  browser (url + title), terminal (output), csv (data + stats),
  docx (text), pptx (slides), chat (recent messages).
inputs:
  - { pane_id: "active" }
steps:
  - name: read_pane
    engine: incognide
    action: read_pane
    args:
      paneId: "{{ pane_id }}"
